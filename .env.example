# ---- General ----
NODE_ENV=development
IP_MODE=inspired

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ridgemont?schema=public
REDIS_URL=redis://localhost:6379

# ---- Auth ----
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ---- AI Providers ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Object Storage ----
S3_BUCKET=ridgemont-uploads
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- MCP ----
MCP_GATEWAY_URL=http://localhost:8400

# ---- FastAPI AI Service ----
AI_SERVICE_URL=http://localhost:8500

# ---- News / Ingest ----
NEWS_INGEST_SCHEDULE="0 */4 * * *"
NEWS_API_KEY=

# ---- Feature Flags ----
FEATURE_LABS_ENABLED=true
FEATURE_MEDIA_EXPLORER=true
FEATURE_BLOCKCHAIN_TRACK=false
